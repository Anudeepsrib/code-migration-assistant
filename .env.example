# -----------------------------------------------------------------------------
# Code Migration Assistant - Environment Configuration
# 
# Copy this file to .env and configure as needed.
# All environment variables override values in config.defaults.yaml
# -----------------------------------------------------------------------------

# Configuration File Path (Optional)
# MIGRATION_CONFIG_FILE=/etc/code-migration/config.yaml

# Security
MIGRATION_SECURITY__LEVEL=high
MIGRATION_SECURITY__AUDIT_LOGGING=true
MIGRATION_SECURITY__MAX_FILE_SIZE_KB=5000
MIGRATION_SECURITY__RATE_LIMIT_PER_MINUTE=60

# Analysis & Cost
MIGRATION_ANALYSIS__COST_RATE_PER_HOUR=100.0
MIGRATION_ANALYSIS__MAX_WORKERS=4
MIGRATION_ANALYSIS__TIMEOUT_SECONDS=300

# Server Binding
MIGRATION_SERVER__HOST=0.0.0.0
MIGRATION_SERVER__PORT=8000
# MIGRATION_SERVER__CORS_ORIGINS='["*", "http://localhost:5173"]'

# Observability
MIGRATION_OBSERVABILITY__LOG_LEVEL=INFO
MIGRATION_OBSERVABILITY__LOG_FORMAT=text
# MIGRATION_OTEL_ENDPOINT=http://localhost:4318/v1/traces
